# ── LLM Provider ─────────────────────────────────────────────────
# Options: claude_code, opencode, ollama (leave empty to auto-detect)
PROVIDER=
# Only for ollama provider:
OLLAMA_MODEL=llama3.2

# ── Telegram (optional) ──────────────────────────────────────────
# Get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-token-here
# Comma-separated chat IDs (send /start to the bot to find yours)
TELEGRAM_ALLOWED_IDS=123456789

# ── Discord (optional) ──────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
# Required intents: Message Content
DISCORD_BOT_TOKEN=your-discord-token-here
# Comma-separated user or channel IDs
DISCORD_ALLOWED_IDS=123456789

# ── Shared Settings ─────────────────────────────────────────────
DEFAULT_CWD=.
DEFAULT_MODEL=sonnet
CLAUDE_TIMEOUT=300
SHELL_TIMEOUT=60
MAX_BUDGET_USD=1.0

# ── Digest Settings ─────────────────────────────────────────────
DIGEST_ENABLED=false
DIGEST_DAILY_HOUR=8
DIGEST_WEEKLY_DAY=0
DIGEST_DELIVERY=none
